# ngrok auth token — get from https://dashboard.ngrok.com/get-started/your-authtoken
# Copy this file to .env and replace REDACTED with your real token.
# .env is gitignored — do NOT commit it.
NGROK_AUTHTOKEN=REDACTED

# Static domain claimed in the ngrok dashboard
NGROK_DOMAIN=

# Public base URL (must match NGROK_DOMAIN above)
PUBLIC_HOST=

# JWKS URL for NS SAPP — this is where the SAPP's public keys are published, and where the NS will fetch them to verify signatures.
NS_JWKS_URL=

# IPFS gateway base URL for resolving ipfs:// URIs (with trailing /ipfs/ path, e.g. https://ipfs.io/ipfs/)
VITE_IPFS_GATEWAY=